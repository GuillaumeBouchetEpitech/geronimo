{
  "hello": "world",

  // MARK: shapes
  "shapes": {

    // MARK: cube
    "cube": {
      "alias": 1,
      "extrusion-axis": [1,1,1], // for the future
      "vertices": [
        { "pos": [-0.5,-0.5,-0.5] },
        { "pos": [0.5,-0.5,-0.5] },
        { "pos": [-0.5,0.5,-0.5] },
        { "pos": [0.5,0.5,-0.5] },
        { "pos": [-0.5,-0.5,0.5] },
        { "pos": [0.5,-0.5,0.5] },
        { "pos": [-0.5,0.5,0.5] },
        { "pos": [0.5,0.5,0.5] }
      ],
      // "normals": [
      //   { "norm": [1,0,0] }, // 0
      //   { "norm": [-1,0,0] }, // 1
      //   { "norm": [0,1,0] }, // 2
      //   { "norm": [0,-1,0] }, // 3
      //   { "norm": [0,0,1] }, // 4
      //   { "norm": [0,0,-1] } // 5
      // ],
      "indices": [

        // quad triangle -Z
        { "tri": [0,2,1] /*, "n": 4*/ },
        // quad triangle -Z
        { "tri": [2,3,1] /*, "n": 4*/ },

        // quad triangle +Z
        { "tri": [4,5,6] /*, "n": 5*/ },
        // quad triangle +Z
        { "tri": [6,5,7] /*, "n": 5*/ },

        // quad triangle +X
        { "tri": [1,3,5] /*, "n": 1*/ },
        // quad triangle +X
        { "tri": [5,3,7] /*, "n": 1*/ },

        // quad triangle -X
        { "tri": [0,4,2] /*, "n": 0*/ },
        // quad triangle -X
        { "tri": [4,6,2] /*, "n": 0*/ },

        // quad triangle +Y
        { "tri": [2,6,3] /*, "n": 3*/ },
        // quad triangle +Y
        { "tri": [6,7,3] /*, "n": 3*/ },

        // quad triangle -Y
        { "tri": [0,1,4] /*, "n": 2*/ },
        // quad triangle -Y
        { "tri": [4,1,5] /*, "n": 2*/ }

      ]
    },



    // MARK: half-cube 1
    "half-cube-pos-x-neg-z": {
      "alias": 11,
      "extrusion-axis": [0,1,0], // for the future
      "vertices": [
        { "pos": [-0.5,-0.5,-0.5] }, // 0
        { "pos": [0.5,-0.5,-0.5] }, // 1
        { "pos": [-0.5,0.5,-0.5] }, // 2
        { "pos": [0.5,0.5,-0.5] }, // 3
        { "pos": [-0.5,-0.5,0.5] }, // 4
        { "pos": [0.5,-0.5,0.5] }, // 5 -> unused
        { "pos": [-0.5,0.5,0.5] }, // 6
        { "pos": [0.5,0.5,0.5] }  // 7 -> unused
      ],
      "indices": [

        // quad triangle -Z
        { "tri": [0,2,1] /*, "n": 4*/ },
        // quad triangle -Z
        { "tri": [2,3,1] /*, "n": 4*/ },

        // // quad triangle +Z
        // { "tri": [4,5,6] /*, "n": 5*/ },
        // // quad triangle +Z
        // { "tri": [6,5,7] /*, "n": 5*/ },

        // // quad triangle +X
        // { "tri": [1,3,5] /*, "n": 1*/ },
        // // quad triangle +X
        // { "tri": [5,3,7] /*, "n": 1*/ },

        // quad triangle -X
        { "tri": [0,4,2] /*, "n": 0*/ },
        // quad triangle -X
        { "tri": [4,6,2] /*, "n": 0*/ },

        // quad triangle +Y
        { "tri": [2,6,3] /*, "n": 3*/ },
        // // quad triangle +Y
        // { "tri": [6,7,3] /*, "n": 3*/ },

        // quad triangle -Y
        { "tri": [0,1,4] /*, "n": 2*/ },
        // // quad triangle -Y
        // { "tri": [4,1,5] /*, "n": 2*/ }

        // quad triangle slice
        { "tri": [4,3,6] /*, "n": 2*/ },
        { "tri": [1,3,4] /*, "n": 2*/ }

      ]
    },

    "half-cube-pos-y-neg-z": {
      "alias": 12,
      "ref": "half-cube-pos-x-neg-z",
      "extrusion-axis": [1,0,0], // for the future
      "transforms": [
        { "type": "rotate", "axis": [0,0,1], "angle": 90 },
        { "type": "apply" }
      ]
    },

    "half-cube-neg-x-neg-z": {
      "alias": 13,
      "ref": "half-cube-pos-x-neg-z",
      "extrusion-axis": [0,1,0], // for the future
      "transforms": [
        { "type": "rotate", "axis": [0,0,1], "angle": 180 },
        { "type": "apply" }
      ]
    },

    "half-cube-neg-y-neg-z": {
