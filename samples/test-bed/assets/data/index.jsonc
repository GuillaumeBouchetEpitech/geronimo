      "extrusion-axis": [0,0,0], // for the future
      "transforms": [
        { "type": "rotate", "axis": [0,1,0], "angle": 180 },
        // { "type": "rotate", "axis": [0,0,1], "angle": 0 },
        { "type": "apply" }
      ]
    },




    // MARK: reverse corners 1
    "rev-corner-neg-x-neg-y-neg-z": {
      "alias": 61,
      "extrusion-axis": [0,0,0], // for the future
      "vertices": [
        { "pos": [-0.5,-0.5,-0.5] },
        { "pos": [0.5,-0.5,-0.5] },
        { "pos": [-0.5,0.5,-0.5] },
        { "pos": [0.5,0.5,-0.5] },
        { "pos": [-0.5,-0.5,0.5] },
        { "pos": [0.5,-0.5,0.5] },
        { "pos": [-0.5,0.5,0.5] },
        { "pos": [0.5,0.5,0.5] }
      ],
      "indices": [

        // quad triangle -Z
        { "tri": [0,2,1] /*, "n": 4*/ },
        // quad triangle -Z
        { "tri": [2,3,1] /*, "n": 4*/ },

        // quad triangle +Z
        { "tri": [4,5,6] /*, "n": 5*/ },
        // quad triangle +Z
        // { "tri": [6,5,7] /*, "n": 5*/ },

        // quad triangle +X
        { "tri": [1,3,5] /*, "n": 1*/ },
        // quad triangle +X
        // { "tri": [5,3,7] /*, "n": 1*/ },

        // quad triangle -X
        { "tri": [0,4,2] /*, "n": 0*/ },
        // quad triangle -X
        { "tri": [4,6,2] /*, "n": 0*/ },

        // quad triangle +Y
        { "tri": [2,6,3] /*, "n": 3*/ },
        // quad triangle +Y
        // { "tri": [6,7,3] /*, "n": 3*/ },

        // quad triangle -Y
        { "tri": [0,1,4] /*, "n": 2*/ },
        // quad triangle -Y
        { "tri": [4,1,5] /*, "n": 2*/ },

        // bonus triangle
        { "tri": [6,5,3] /*, "n": 2*/ }
     ]
    },

    "rev-corner-neg-x-pos-y-neg-z": {
