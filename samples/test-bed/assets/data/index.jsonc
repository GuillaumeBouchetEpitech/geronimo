      "extrusion-axis": [1,0,0], // for the future
      "transforms": [
        { "type": "rotate", "axis": [0,0,1], "angle":  90 },
        { "type": "rotate", "axis": [0,1,0], "angle": 180 },
        { "type": "apply" }
      ]
    },

    // MARK: half-cube 3
    "half-cube-neg-x-neg-y": {
      "alias": 31,
      "ref": "half-cube-pos-x-neg-z",
      "extrusion-axis": [0,0,1], // for the future
      "transforms": [
        { "type": "rotate", "axis": [1,0,0], "angle": -90 },
        // { "type": "rotate", "axis": [0,1,0], "angle": 180 },
        { "type": "apply" }
      ]
    },

    "half-cube-pos-x-neg-y": {
      "alias": 32,
      "ref": "half-cube-pos-x-neg-z",
      "extrusion-axis": [0,0,1], // for the future
      "transforms": [
        { "type": "rotate", "axis": [1,0,0], "angle": -90 },
        { "type": "rotate", "axis": [0,1,0], "angle": -90 },
        { "type": "apply" }
