    },

    "half-cube-pos-x-pos-y": {
      "alias": 33,
      "ref": "half-cube-pos-x-neg-z",
      "extrusion-axis": [0,0,1], // for the future
      "transforms": [
        { "type": "rotate", "axis": [1,0,0], "angle": -90 },
        { "type": "rotate", "axis": [0,1,0], "angle": -180 },
        { "type": "apply" }
      ]
    },

    "half-cube-neg-x-pos-y": {
      "alias": 34,
      "ref": "half-cube-pos-x-neg-z",
      "extrusion-axis": [0,0,1], // for the future
      "transforms": [
        { "type": "rotate", "axis": [1,0,0], "angle": -90 },
        { "type": "rotate", "axis": [0,1,0], "angle": -270 },
        { "type": "apply" }
      ]
    },

    // MARK: corners 1
    "corner-neg-x-neg-y-neg-z": {
      "alias": 41,
      "extrusion-axis": [0,0,0], // for the future
      "vertices": [
        { "pos": [-0.5,-0.5,-0.5] }, // 0
        { "pos": [0.5,-0.5,-0.5] }, // 1
        { "pos": [-0.5,0.5,-0.5] }, // 2
        { "pos": [0.5,0.5,-0.5] }, // 3 -> unused
        { "pos": [-0.5,-0.5,0.5] } // 4
      ],
      "indices": [
        { "tri": [0,2,1] /*, "n": 4*/ },
        { "tri": [0,4,2] /*, "n": 0*/ },
        { "tri": [0,1,4] /*, "n": 2*/ },
        { "tri": [1,2,4] /*, "n": 2*/ }
      ]
    },

    "corner-neg-x-pos-y-neg-z": {
      "alias": 42,
      "ref": "corner-neg-x-neg-y-neg-z",
      "extrusion-axis": [0,0,0], // for the future
      "transforms": [
        { "type": "rotate", "axis": [0,0,1], "angle": 90 },
